{
  "productName": "xpmt",
  "version": "0.1.0",
  "identifier": "com.xcognvis.xpmt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "XPMT",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3RDNDOUUwRTQyRDU4MTYKUldRV1dDM2s0TW5UdDdjYkhHSm5nNTRVNlEvdDdmcHdhSVlnTlRqMUNydGp6QzV3NGFkTlNlbGUK",
      "endpoints": [
        "https://github.com/AquilaWilfred/xpmt/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
